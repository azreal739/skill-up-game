{
  "name": "engineering-academy",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/engineering-academy/src",
  "prefix": "ea",
  "tags": [
    "type:app",
    "scope:academy"
  ],
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "options": {
        "outputPath": "dist/apps/engineering-academy",
        "index": "apps/engineering-academy/src/index.html",
        "browser": "apps/engineering-academy/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/engineering-academy/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/engineering-academy/public",
            "output": ""
          }
        ],
        "styles": [
          "apps/engineering-academy/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "3.25MB",
              "maximumError": "3.75MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kB",
              "maximumError": "16kB"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "engineering-academy:build:production"
        },
        "development": {
          "buildTarget": "engineering-academy:build:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "test": {
      "executor": "@angular-devkit/build-angular:karma",
      "options": {
        "karmaConfig": "apps/engineering-academy/karma.conf.js",
        "polyfills": [
          "zone.js",
          "zone.js/testing"
        ],
        "tsConfig": "apps/engineering-academy/tsconfig.spec.json",
        "inlineStyleLanguage": "scss",
        "styles": [
          "apps/engineering-academy/src/styles.scss"
        ],
        "scripts": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
